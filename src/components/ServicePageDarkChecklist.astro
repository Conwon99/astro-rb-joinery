---
interface Props {
  heading: string;
  paragraphs: string[];
  bullets: string[];
  primaryImage: string;
  primaryImageAlt: string;
  secondaryImage?: string;
  secondaryImageAlt?: string;
}

const {
  heading,
  paragraphs,
  bullets,
  primaryImage,
  primaryImageAlt,
  secondaryImage,
  secondaryImageAlt = "",
} = Astro.props;
---

<section
  class="bg-black px-4 py-14 text-white md:py-20 lg:py-24"
  aria-labelledby="service-dark-checklist-heading"
>
  <div class="container mx-auto max-w-7xl">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-14 xl:gap-16">
      <div class="text-left">
        <h2
          id="service-dark-checklist-heading"
          class="font-display mb-6 text-3xl font-bold leading-tight text-white md:mb-8 md:text-4xl lg:text-[2.35rem] xl:text-5xl"
        >
          {heading}
        </h2>
        <div class="mb-8 space-y-5">
          {
            paragraphs.map((p) => (
              <p class="text-base leading-relaxed text-white/90 md:text-lg">{p}</p>
            ))
          }
        </div>
        <ul class="space-y-4" role="list">
          {
            bullets.map((item) => (
              <li class="flex gap-4">
                <span
                  class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[#5B6EF5]"
                  aria-hidden="true"
                >
                  <svg
                    class="h-4 w-4 text-white"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M5 13l4 4L19 7" />
                  </svg>
                </span>
                <span class="text-base leading-relaxed text-white/95 md:text-lg">{item}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="relative mx-auto w-full max-w-xl lg:mx-0 lg:max-w-none">
        <img
          src={primaryImage}
          alt={primaryImageAlt}
          class="aspect-[4/3] w-full rounded-2xl object-cover shadow-xl"
          width="800"
          height="600"
          loading="lazy"
          decoding="async"
        />
        {
          secondaryImage && (
            <div class="absolute -bottom-4 -right-2 w-[42%] max-w-[220px] overflow-hidden rounded-2xl border-2 border-neutral-600 shadow-2xl sm:-bottom-5 sm:-right-4 lg:-bottom-6 lg:-right-6 lg:max-w-[260px]">
              <img
                src={secondaryImage}
                alt={secondaryImageAlt}
                class="aspect-[4/3] w-full object-cover"
                width="400"
                height="300"
                loading="lazy"
                decoding="async"
              />
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
