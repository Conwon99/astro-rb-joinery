---
import { Button } from "./ui/button";

interface Props {
  heading: string;
  body: string;
  primaryImage: string;
  primaryImageAlt: string;
  secondaryImage?: string;
  secondaryImageAlt?: string;
}

const {
  heading,
  body,
  primaryImage,
  primaryImageAlt,
  secondaryImage,
  secondaryImageAlt = "",
} = Astro.props;
---

<section class="bg-black px-4 py-14 md:py-20 lg:py-24" aria-labelledby="service-split-heading">
  <div class="container mx-auto max-w-7xl">
    <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-14 xl:gap-16">
      <div class="relative mx-auto w-full max-w-xl lg:mx-0 lg:max-w-none">
        <img
          src={primaryImage}
          alt={primaryImageAlt}
          class="aspect-[4/3] w-full rounded-2xl object-cover shadow-xl"
          width="800"
          height="600"
          loading="eager"
          decoding="async"
        />
        {
          secondaryImage && (
            <div class="absolute -bottom-4 -right-2 w-[44%] max-w-[240px] overflow-hidden rounded-2xl border-2 border-white/25 shadow-2xl sm:-bottom-5 sm:-right-4 lg:-bottom-6 lg:-right-6 lg:max-w-[280px]">
              <img
                src={secondaryImage}
                alt={secondaryImageAlt}
                class="aspect-[4/3] w-full object-cover"
                width="400"
                height="300"
                loading="lazy"
                decoding="async"
              />
            </div>
          )
        }
      </div>

      <div class="text-left">
        <h2
          id="service-split-heading"
          class="font-display mb-6 text-3xl font-bold leading-tight text-white md:text-4xl lg:text-[2.35rem] xl:text-5xl"
        >
          {heading}
        </h2>
        <p class="mb-8 max-w-xl text-base leading-relaxed text-white/90 md:text-lg">
          {body}
        </p>
        <Button
          client:load
          onClick={() => (window.location.href = "/contact")}
          className="rounded-full bg-[#E9B24E] px-8 py-6 text-base font-semibold text-neutral-900 shadow-md transition-colors hover:bg-[#ddb044] md:text-lg"
        >
          Get A Free Quote
        </Button>
      </div>
    </div>
  </div>
</section>
