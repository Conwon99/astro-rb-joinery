---
interface Props {
  heading: string;
  paragraphs: readonly string[] | string[];
  primaryImage: string;
  primaryImageAlt: string;
  secondaryImage?: string;
  secondaryImageAlt?: string;
}

const {
  heading,
  paragraphs,
} = Astro.props;
---

<section
  class="bg-neutral-950 px-4 py-14 text-white md:py-20 lg:py-24"
  aria-labelledby="service-why-choose-heading"
>
  <div class="container mx-auto max-w-7xl">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-14 xl:gap-16">
      <div class="relative mx-auto w-full max-w-xl lg:mx-0 lg:max-w-none">
        <img
          src="/about%20Us%20Ryan.webp"
          alt="RB Joinery at work"
          class="aspect-[4/3] w-full rounded-2xl object-cover shadow-xl"
          width="800"
          height="600"
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="text-left lg:pl-4">
        <h2
          id="service-why-choose-heading"
          class="font-display mb-6 text-3xl font-bold leading-tight tracking-tight text-white md:mb-8 md:text-4xl lg:text-[2.35rem] xl:text-5xl"
        >
          {heading}
        </h2>
        <div class="space-y-5">
          {
            paragraphs.map((p) => (
              <p class="text-base leading-relaxed text-white/90 md:text-lg md:leading-relaxed">{p}</p>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
