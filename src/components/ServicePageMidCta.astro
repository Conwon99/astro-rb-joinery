---
import TrackedPhoneLink from "./TrackedPhoneLink";

interface Props {
  line1?: string;
  line2?: string;
}

const {
  line1 = "Start your project with",
  line2 = "expert joinery today",
} = Astro.props;
---

<section
  class="relative overflow-hidden bg-neutral-950 px-4 py-16 text-white md:py-20 lg:py-24"
  aria-labelledby="service-mid-cta-heading"
>
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_70%_20%,rgba(34,197,94,0.12),transparent)]"
    aria-hidden="true"
  />
  <div class="container relative mx-auto max-w-6xl">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-14">
      <div>
        <h2
          id="service-mid-cta-heading"
          class="font-display text-3xl font-bold leading-[1.15] tracking-tight md:text-4xl lg:text-5xl"
        >
          <span class="block text-white">{line1}</span>
          <span class="mt-1 block text-green-400">{line2}</span>
        </h2>
        <p class="mt-6 font-display text-2xl font-semibold text-white/95 md:text-3xl">
          <TrackedPhoneLink
            client:load
            className="transition-colors hover:text-green-400"
          />
        </p>
      </div>
      <div class="flex justify-start lg:justify-end">
        <a
          href="/contact/"
          class="inline-flex items-center justify-center rounded-full bg-[#E9B24E] px-10 py-7 text-base font-semibold text-neutral-900 shadow-lg transition-colors hover:bg-[#ddb044] md:text-lg"
        >
          Get a free quote
        </a>
      </div>
    </div>
  </div>
</section>
