---
import '../index.css';
import MobileContactFab from '../components/MobileContactFab.astro';
import { LOCATIONS } from '../data/locations';
import { CANONICAL_PHONE_E164 } from '../constants/phone';

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  robots?: string;
  hideScrollbar?: boolean;
  breadcrumbItems?: BreadcrumbItem[];
  /** Extra JSON-LD for location hub / service pages */
  locationLocalBusinessJson?: Record<string, unknown> | null;
}

const {
  title = "RB Joinery | Joinery & Building Services Ayrshire & Glasgow",
  description = "Professional joinery & building services in Ayrshire and Glasgow. House extensions, loft conversions, garden rooms, kitchens, and home improvements. Free quotes available.",
  canonical = "https://rbjoinery.com/",
  image = "https://rbjoinery.com/rblogo - Edited.png",
  robots = "index, follow",
  hideScrollbar = false,
  breadcrumbItems,
  locationLocalBusinessJson = null,
} = Astro.props;

const mergedAreaServed = [
  ...LOCATIONS.map((l) => ({
    "@type": "City",
    name: l.name,
    containedInPlace: {
      "@type": "AdministrativeArea",
      name: l.region,
    },
  })),
  {
    "@type": "AdministrativeArea",
    name: "Ayrshire",
    containedInPlace: { "@type": "Country", "name": "Scotland" },
  },
];

const breadcrumbJsonLd =
  breadcrumbItems && breadcrumbItems.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: breadcrumbItems.map((item, i) => ({
          "@type": "ListItem",
          position: i + 1,
          name: item.name,
          item: item.url.startsWith("http") ? item.url : `https://rbjoinery.com${item.url.startsWith("/") ? item.url : `/${item.url}`}`,
        })),
      }
    : null;
---

<!DOCTYPE html>
<html lang="en" class:list={[hideScrollbar && "hide-scrollbar"]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="joinery ayrshire, joinery glasgow, house extensions ayrshire, house extensions glasgow, loft conversions ayrshire, loft conversions glasgow, garden rooms ayrshire, garden rooms glasgow, kitchens ayrshire, kitchens glasgow, home improvements ayrshire, home improvements glasgow, carpenter ayrshire, carpenter glasgow, joinery contractors ayrshire, joinery contractors glasgow, building services ayrshire, building services glasgow, rb joinery" />
    <meta name="author" content="RB Joinery" />
    <meta name="robots" content={robots} />
    <meta name="language" content="English" />
    <meta name="geo.region" content="GB-SCT" />
    <meta name="geo.placename" content="Ayrshire & Glasgow, Scotland" />
    
    <!-- Google Analytics -->
    <script is:inline define:vars={{ gtagId: "G-6CMJ7GLMSY" }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', gtagId);
    </script>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-6CMJ7GLMSY"></script>
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonical} />
    
    <!-- Enhanced JSON-LD Schema for LocalBusiness -->
    <script type="application/ld+json" set:html={`${JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["LocalBusiness", "LandscapingBusiness", "HomeImprovementContractor", "ContractorService"],
      "name": "RB Joinery",
      "alternateName": "RB Joinery & Building Services",
      "description": description,
      "url": "https://rbjoinery.com/",
      "telephone": CANONICAL_PHONE_E164,
      "email": "Ryan@rbjoinery.com",
      "foundingDate": "2020",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Kilmarnock",
        "addressRegion": "Ayrshire",
        "addressCountry": "Scotland",
        "postalCode": "KA1"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "55.4586",
        "longitude": "-4.6292"
      },
      "areaServed": mergedAreaServed,
      "serviceType": [
        "House Extensions", "Loft Conversions", "Garden Rooms", "Kitchen Installation",
        "Home Improvements", "Door Fitting", "Bathroom Fitting", "Joinery Services", "Carpentry", "Custom Built-ins",
        "Staircases", "Doors and Windows", "Fitted Furniture", "Building Services",
        "Renovations", "Structural Work", "Interior Design", "Bespoke Joinery",
        "Commercial Joinery", "Maintenance and Repairs"
      ],
      "openingHours": [
        "Mo 08:00-18:00", "Tu 08:00-18:00", "We 08:00-18:00",
        "Th 08:00-18:00", "Fr 08:00-18:00", "Sa 09:00-16:00", "Su 10:00-15:00"
      ],
      "priceRange": "$$",
      "image": [
        "https://rbjoinery.com/rblogo - Edited.png",
        "https://rbjoinery.com/RB joinery back2.jpg"
      ],
      "logo": "https://rbjoinery.com/rblogo - Edited.png",
      "sameAs": [],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "15",
        "bestRating": "5",
        "worstRating": "1"
      }
    })}`} />

    {breadcrumbJsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
    )}
    {locationLocalBusinessJson && (
      <script type="application/ld+json" set:html={JSON.stringify(locationLocalBusinessJson)} />
    )}
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/rblogo - Edited.png" />
    <link rel="alternate icon" href="/rblogo - Edited.png" />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Figtree:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Outfit:wght@400;500;600;700;800&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-35QPRJ2GD9"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-35QPRJ2GD9');
    </script>

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image:width" content="800" />
    <meta property="og:image:height" content="800" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta property="og:image:alt" content="RB Joinery Logo" />
    <meta property="og:site_name" content="RB Joinery" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <meta name="twitter:image:alt" content="RB Joinery Logo" />
    
    <meta name="theme-color" content="#1e40af" />
    <meta name="msapplication-TileColor" content="#1e40af" />
    <meta name="msapplication-TileImage" content="https://rbjoinery.com/rblogo - Edited.png" />
  </head>

  <body class:list={[hideScrollbar && "hide-scrollbar"]}>
    {breadcrumbItems && breadcrumbItems.length > 0 && (
      <div class="border-b border-gray-200 bg-gray-50/95 pt-20 print:hidden">
        <div class="container mx-auto max-w-7xl px-4 py-3">
          <nav aria-label="Breadcrumb">
            <ol class="flex flex-wrap items-center gap-2 text-sm text-gray-600">
              {breadcrumbItems.map((item, index) => (
                <li class="flex items-center gap-2">
                  {index > 0 && <span class="text-gray-400" aria-hidden="true">/</span>}
                  {index < breadcrumbItems.length - 1 ? (
                    <a href={item.url} class="text-green-700 hover:underline">
                      {item.name}
                    </a>
                  ) : (
                    <span class="font-medium text-gray-900" aria-current="page">
                      {item.name}
                    </span>
                  )}
                </li>
              ))}
            </ol>
          </nav>
        </div>
      </div>
    )}
    <slot />
    <MobileContactFab />
  </body>
</html>

