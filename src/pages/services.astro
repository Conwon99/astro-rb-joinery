---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation';
import Footer from '../components/Footer';
import { SERVICES } from '../data/services';
import { LOCATIONS } from '../data/locations';
import { servicesHub } from '../content/site';
import { SITE_ORIGIN } from '../constants/site';

const title = servicesHub.metaTitle;
const description = servicesHub.metaDescription;
const canonical = `${SITE_ORIGIN}/services/`;
---

<Layout title={title} description={description} canonical={canonical}>
  <Navigation client:load />

  <main class="min-h-screen pt-24">
    <section
      class="relative bg-gradient-to-br from-blue-50 to-green-50 py-16 px-4 border-b border-gray-100"
    >
      <div class="container mx-auto max-w-6xl text-center">
        <h1
          class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 mb-6"
        >
          {servicesHub.h1}
        </h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          {servicesHub.lead}
        </p>
      </div>
    </section>

    <section class="py-16 px-4 bg-gradient-to-b from-background to-[hsl(var(--muted))]">
      <div class="container mx-auto max-w-7xl">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {
            SERVICES.map((service) => (
              <a
                href={service.href}
                class="group overflow-hidden flex flex-col rounded-3xl bg-card shadow-[var(--shadow-card)] hover:shadow-[var(--shadow-soft)] transition-[var(--transition-smooth)] hover:scale-[1.02] h-full text-left no-underline"
              >
                <div class="aspect-[4/3] overflow-hidden">
                  <img
                    src={service.image}
                    alt={`${service.title} — RB Joinery`}
                    class="w-full h-full object-cover object-center transition-transform duration-300 group-hover:scale-110"
                    loading="lazy"
                  />
                </div>
                <div class="p-6 flex flex-col flex-grow">
                  <h2 class="font-display text-2xl font-bold text-[hsl(var(--asphalt-grey))] mb-2">
                    {service.title}
                  </h2>
                  <p class="text-[hsl(var(--asphalt-grey))] opacity-80 mb-4">
                    {service.description}
                  </p>
                  <span class="mt-auto inline-flex items-center text-green-600 font-semibold group-hover:underline">
                    More about {service.title}
                    <span class="ml-1" aria-hidden="true">→</span>
                  </span>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-white px-4 py-16 border-t border-gray-100">
      <div class="container mx-auto max-w-5xl">
        <div class="grid gap-12 lg:grid-cols-[1.4fr_1fr] lg:items-start">
          <div class="space-y-5 text-lg leading-relaxed text-gray-700">
            <h2 class="font-display text-3xl font-bold text-gray-900 md:text-4xl">
              Joinery and building services across Ayrshire and Glasgow
            </h2>
            <p>
              RB Joinery takes on everything from larger projects like
              <a href="/house-extensions/" class="text-green-700 underline hover:text-green-800">house extensions</a>
              and
              <a href="/loft-conversions/" class="text-green-700 underline hover:text-green-800">loft conversions</a>
              to practical upgrades such as
              <a href="/kitchen-installation/" class="text-green-700 underline hover:text-green-800">kitchen installation</a>,
              <a href="/door-fitting/" class="text-green-700 underline hover:text-green-800">door fitting</a>,
              <a href="/bathroom-fitting/" class="text-green-700 underline hover:text-green-800">bathroom fitting</a>,
              and
              <a href="/home-improvements/" class="text-green-700 underline hover:text-green-800">home improvements</a>.
            </p>
            <p>
              We work with homeowners who want clear advice before work starts, tidy workmanship during the job, and a finish that still feels solid after daily use. If you are not sure which service page best matches your project, you can
              <a href="/contact/" class="text-green-700 underline hover:text-green-800">contact us for a free quote</a>
              or browse the towns we cover on our
              <a href="/locations/" class="text-green-700 underline hover:text-green-800">locations page</a>.
            </p>
          </div>

          <div class="rounded-2xl border border-green-100 bg-green-50 p-6">
            <h2 class="font-display text-2xl font-bold text-gray-900">Popular service areas</h2>
            <ul class="mt-4 grid gap-3 text-sm font-medium text-gray-700 sm:grid-cols-2 lg:grid-cols-1">
              {
                LOCATIONS.map((loc) => (
                  <li>
                    <a href={`/${loc.slug}/`} class="text-green-700 hover:underline">
                      Joinery in {loc.name}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer client:load />

  <script>
    if (typeof window !== 'undefined') {
      window.scrollTo(0, 0);
    }
  </script>
</Layout>
