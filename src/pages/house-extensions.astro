---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation';
import Footer from '../components/Footer';
import { Button } from '../components/ui/button';
import { Phone } from 'lucide-react';
import { SERVICES } from '../data/services';

const title = "House Extensions Ayrshire & Glasgow | Professional Extension Services | RB Joinery";
const description = "Professional house extension services in Ayrshire and Glasgow. Planning, design, and construction of single and two-storey extensions. Free quotes available.";
const canonical = "https://rbjoinery.com/house-extensions";

const heroImage = SERVICES.find((s) => s.href === "/house-extensions")!.image;
---

<Layout title={title} description={description} canonical={canonical}>
  <Navigation client:load />
  
  <main class="min-h-screen">
    <!-- Hero — same image as service card -->
    <section class="relative flex min-h-[420px] items-center overflow-hidden px-4 pb-20 pt-28 md:min-h-[480px] md:pt-32">
      <div
        class="absolute inset-0 bg-cover bg-center"
        style={`background-image: url(${JSON.stringify(heroImage)})`}
        aria-hidden="true"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/65 via-black/50 to-black/70" aria-hidden="true" />
      <div class="container relative z-10 mx-auto max-w-6xl">
        <h1 class="font-display mb-6 text-center text-4xl font-bold text-white drop-shadow-md md:text-5xl lg:text-6xl">
          House Extensions Ayrshire & Glasgow
        </h1>
        <p class="mx-auto mb-8 max-w-3xl text-center text-xl text-white/95">
          Professional house extension services with planning support and expert construction.
        </p>
        <div class="flex flex-col justify-center gap-4 sm:flex-row">
          <Button 
            onClick={() => window.location.href = '/contact'}
            className="bg-green-600 hover:bg-green-700 text-white px-8 py-4 text-lg font-semibold rounded-full"
            client:load
          >
            Get Free Quote
          </Button>
          <Button 
            onClick={() => window.location.href = 'tel:+447927726622'}
            variant="outline"
            className="border-2 border-white bg-white/10 px-8 py-4 text-lg font-semibold text-white backdrop-blur-sm hover:bg-white/20 hover:text-white"
            client:load
          >
            <Phone class="w-5 h-5 mr-2" />
            Call 07927 726622
          </Button>
        </div>
      </div>
    </section>
    
    <!-- Rest of content would go here - similar to original HouseExtensions.tsx -->
  </main>
  
  <Footer client:load />
  
  <script>
    if (typeof window !== 'undefined') {
      window.scrollTo(0, 0);
    }
  </script>
</Layout>


