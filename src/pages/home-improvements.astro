---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation';
import Footer from '../components/Footer';
import ServicePageProse from '../components/ServicePageProse.astro';
import ServicePageSplitIntro from '../components/ServicePageSplitIntro.astro';
import ServicePageDarkChecklist from '../components/ServicePageDarkChecklist.astro';
import ServicePageWhyChooseSplit from '../components/ServicePageWhyChooseSplit.astro';
import ServicePageGoogleReviews from '../components/ServicePageGoogleReviews';
import ServicePageContactSplit from '../components/ServicePageContactSplit';
import ServicePageHero from '../components/ServicePageHero';
import FAQ from '../components/FAQ';
import ServiceAreas from '../components/ServiceAreas';
import { SERVICES } from '../data/services';
import {
  faqItems,
  serviceFaqBySlug,
  serviceFaqIntroBySlug,
  servicePages,
  servicePageWhyChoose,
} from '../content/site';
import { googleReviewsBand } from '../content/servicePageReviews';

const page = servicePages["home-improvements"];
const title = page.metaTitle;
const description = page.metaDescription;
const canonical = "https://rbjoinery.com/home-improvements/";

const svc = SERVICES.find((s) => s.href === "/home-improvements")!;
const heroImage = svc.image;

const breadcrumbItems = [
  { name: "Home", url: "/" },
  { name: "Services", url: "/services" },
  { name: "Home Improvements", url: "/home-improvements" },
];
---

<Layout title={title} description={description} canonical={canonical} breadcrumbItems={breadcrumbItems} hideScrollbar={true}>
  <Navigation client:load />
  
  <main class="min-h-screen">
    <ServicePageHero
      client:load
      backgroundImage={heroImage}
      heroH1={page.heroH1}
      heroLead={page.heroLead}
      reviewCount={googleReviewsBand.summary.reviewCount}
      reviewLink={googleReviewsBand.summary.reviewCountLink}
    />

    <ServicePageSplitIntro
      heading={page.splitIntro.heading}
      body={page.splitIntro.body}
      primaryImage={svc.image}
      primaryImageAlt={page.splitIntro.heading}
      secondaryImage={svc.splitSecondaryImage}
    />

    {
      page.darkChecklistSection && (
        <ServicePageDarkChecklist
          heading={page.darkChecklistSection.heading}
          paragraphs={page.darkChecklistSection.paragraphs}
          bullets={page.darkChecklistSection.bullets}
          primaryImage={page.darkChecklistSection.primaryImage}
          primaryImageAlt={page.darkChecklistSection.primaryImageAlt}
          secondaryImage={page.darkChecklistSection.secondaryImage}
          secondaryImageAlt={page.darkChecklistSection.secondaryImageAlt}
        />
      )
    }

    <ServicePageWhyChooseSplit
      heading={servicePageWhyChoose.heading}
      paragraphs={servicePageWhyChoose.paragraphs}
      primaryImage={svc.image}
      primaryImageAlt={`${svc.title} — RB Joinery`}
      secondaryImage={svc.splitSecondaryImage}
      secondaryImageAlt={`RB Joinery ${svc.title.toLowerCase()} work`}
    />

    <ServicePageGoogleReviews client:load />

    <ServicePageContactSplit
      client:load
      backgroundImage={heroImage}
      serviceLabel={svc.title}
    />

    <ServiceAreas client:load />
    <FAQ
      client:load
      items={serviceFaqBySlug["home-improvements"] ?? faqItems}
      introDescription={serviceFaqIntroBySlug["home-improvements"]}
    />

    <ServicePageProse content={page} />
  </main>
  
  <Footer client:load />
  
  <script>
    if (typeof window !== 'undefined') {
      window.scrollTo(0, 0);
    }
  </script>
</Layout>


